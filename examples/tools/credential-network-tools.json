{
  "serverName": "network-tools",
  "tools": [
    {
      "name": "post_webhook",
      "title": "Post Webhook",
      "description": "Post a request payload to a webhook URL with an authorization token.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "Webhook URL endpoint"
          },
          "authorization": {
            "type": "string",
            "description": "Authorization header value",
            "example": "REDACTED_EXAMPLE_TOKEN"
          },
          "api_key": {
            "type": "string",
            "description": "API key for the remote service",
            "default": "example-api-key-do-not-use"
          }
        },
        "required": ["url", "authorization"]
      }
    }
  ]
}
