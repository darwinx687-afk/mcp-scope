{
  "name": "@mcp-scope/report",
  "version": "0.0.0",
  "description": "Report rendering placeholders for MCP Scope.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean && tsc -p tsconfig.build.json",
    "test": "vitest run --config ../../vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mcp-scope/core": "workspace:*"
  }
}
