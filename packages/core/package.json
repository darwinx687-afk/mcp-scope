{
  "name": "@mcp-scope/core",
  "version": "0.0.0",
  "description": "Core constants and shared placeholder types for MCP Scope.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run --config ../../vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
